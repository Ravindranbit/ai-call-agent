PORT=3000
TWILIO_DEFAULT_VOICE= leave_empty
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# AI Provider: 'nvidia', 'groq', or 'auto' (tries nvidia first, then groq)
AI_PROVIDER=auto

# NVIDIA NIM (get key from https://build.nvidia.com)
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here
NVIDIA_MODEL=sarvamai/sarvam-m

# Groq (fallback)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

PUBLIC_URL= copy_paste_your_cloudflare_tunnel_url
BASE_URL=copy_paste_your_cloudflare_tunnel_url