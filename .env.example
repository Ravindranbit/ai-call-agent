PORT=3000
TWILIO_DEFAULT_VOICE=leave_empty

# Twilio Credentials
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Phone numbers to call when testing /api/call/make-all (comma separated)
OUTBOUND_NUMBERS=+919894860308,+91XXXXXXXXXX

# Database & Cache (Required for Production)
DATABASE_URL=postgresql://user:password@localhost:5432/ai_call_agent
REDIS_URL=redis://localhost:6379

# AI Provider: 'nvidia', 'groq', or 'auto' (hybrid routing)
AI_PROVIDER=auto

# NVIDIA NIM (Primary for Indian Languages)
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here
NVIDIA_MODEL=sarvamai/sarvam-m

# Groq (Fast Fallback)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Webhook URLs
PUBLIC_URL=https://your-cloudflare-tunnel.trycloudflare.com
BASE_URL=https://your-cloudflare-tunnel.trycloudflare.com